generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String

  createdAt DateTime @default(now())
}

model License {
  id           String   @id @default(cuid())
  key          String   @unique

  organization String
  plan         String
  status       String

  maxDevices   Int

  expiresAt    DateTime

  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  activations  Activation[]
}

model Activation {
  id         String   @id @default(cuid())

  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  deviceId   String
  deviceName String?

  ipAddress  String?

  createdAt  DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(cuid())

  action        String

  licenseId     String?

  organization  String?

  actorRole     String?

  actorName     String?

  description   String?

  createdAt     DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique

  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  status    String   @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(cuid())

  name        String       @unique
  description String?

  teamMembers TeamMember[]

  permissions Permission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())

  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])

  permission  String

  createdAt   DateTime @default(now())
}

model SecurityPolicy {
  id          String   @id @default(cuid())

  name        String   @unique

  enabled     Boolean  @default(true)

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
