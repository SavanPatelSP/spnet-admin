generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(cuid())
  name  String
  email String @unique
  role  String

  createdAt DateTime @default(now())
}

model License {
  id String @id @default(cuid())

  key String @unique

  organization String

  plan String

  status String

  maxDevices Int

  expiresAt DateTime

  notes String?

  createdAt DateTime @default(now())

  activations Activation[]
}

model Activation {
  id String @id @default(cuid())

  licenseId String

  deviceId String

  deviceName String?

  ipAddress String?

  activatedAt DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)
}

model SecurityPolicy {
  id String @id @default(cuid())

  role String @unique

  revalidationDays Int
}
