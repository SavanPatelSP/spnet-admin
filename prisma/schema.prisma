generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String

  createdAt DateTime @default(now())
}

model License {
  id           String   @id @default(cuid())
  key          String   @unique

  organization String
  plan         String
  status       String

  maxDevices   Int

  expiresAt    DateTime

  notes        String?

  featureFlags String?   // JSON string of feature flag key-value pairs

  trialStartDate DateTime?
  trialEndDate   DateTime?

  parentLicenseId String?
  parentLicense   License?  @relation("LicenseTransfer", fields: [parentLicenseId], references: [id], onDelete: SetNull)
  childLicenses   License[] @relation("LicenseTransfer")

  teamMember   TeamMember?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  activations  Activation[]
  coinBalance  CoinBalance?
  coinTransactions CoinTransaction[]
  gemBalance   GemBalance?
  gemTransactions GemTransaction[]
  premiumSubscriptions PremiumSubscription[]
  premiumRequests    PremiumRequest[]
  supportTickets SupportTicket[]
  tags         LicenseTag[]
  events       LicenseEvent[]
  invoices     Invoice[]

  @@index([expiresAt])
  @@index([status])
  @@index([organization])
  @@index([plan])
  @@index([status, expiresAt])
  @@index([organization, plan])
  @@index([plan, status])
}

model LicenseTag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("gray")
  licenseId String
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([licenseId, name])
}

model LicenseEvent {
  id          String   @id @default(cuid())
  licenseId   String
  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  type        String   // ACTIVATED, DEACTIVATED, SUSPENDED, REACTIVATED, EXPIRED, RENEWED, PLAN_CHANGED, TRANSFERRED, TRIAL_STARTED, TRIAL_CONVERTED, FEATURE_UPDATED, TAG_ADDED, TAG_REMOVED, VALIDATED
  description String?
  metadata    String?  // JSON string
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([licenseId])
  @@index([licenseId, createdAt])
  @@index([type])
  @@index([createdAt])
}

model LicenseTemplate {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  plan          String
  maxDevices    Int      @default(5)
  durationDays  Int      @default(365)
  featureFlags  String?  // JSON string of default feature flag values
  defaultNotes  String?
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model CoinBalance {
  id         String   @id @default(cuid())
  licenseId  String   @unique
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  type       String   @default("FINITE")  // FINITE, PROMOTIONAL, BONUS
  balance    Int      @default(0)
  isInfinite Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model CoinTransaction {
  id           String   @id @default(cuid())
  licenseId    String
  license      License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  type         String   // CREDIT, DEBIT, REFUND, ADJUSTMENT
  amount       Int
  balanceAfter Int
  reason       String?
  description  String?
  performedBy  String?
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([licenseId])
  @@index([licenseId, createdAt])
  @@index([type])
  @@index([createdAt])
}

model GemBalance {
  id         String   @id @default(cuid())
  licenseId  String   @unique
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  type       String   @default("FINITE")  // FINITE, PROMOTIONAL, REWARD
  balance    Int      @default(0)
  isInfinite Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model GemTransaction {
  id           String   @id @default(cuid())
  licenseId    String
  license      License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  type         String   // GRANT, REVOKE, ADJUSTMENT, REWARD
  amount       Int
  balanceAfter Int
  rewardId     String?
  reward       GemReward? @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  reason       String?
  description  String?
  performedBy  String?
  createdAt    DateTime @default(now())

  @@index([licenseId])
  @@index([licenseId, createdAt])
  @@index([type])
  @@index([rewardId])
  @@index([createdAt])
}

model GemReward {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  amount      Int
  category    String   @default("ACHIEVEMENT")  // ACHIEVEMENT, REFERRAL, EVENT, SEASONAL
  active      Boolean  @default(true)
  cooldownDays Int?
  maxClaims   Int?
  budget      Int?
  icon        String?
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions GemTransaction[]
}

model PremiumSubscription {
  id        String   @id @default(cuid())

  licenseId String
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  plan      String
  action    String   // GRANTED, EXTENDED, PLAN_CHANGED, REVOKED, CANCELLED, RENEWED, DOWNGRADED, CONVERTED_TO_LIFETIME

  subscriptionType String @default("MONTHLY")  // MONTHLY, YEARLY, CUSTOM, LIFETIME

  startDate DateTime @default(now())
  endDate   DateTime
  durationDays Int?

  grantedBy String?
  notes     String?

  previousPlan     String?
  previousEndDate  DateTime?

  createdAt DateTime @default(now())

  @@index([licenseId])
  @@index([endDate])
  @@index([plan])
  @@index([licenseId, endDate])
  @@index([action, endDate])
}

model PremiumRequest {
  id            String   @id @default(cuid())

  licenseId     String
  license       License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  organization  String?
  requestedPlan String
  requestedDurationDays Int
  reason        String?
  status        String   @default("PENDING")  // PENDING, APPROVED, REJECTED, EXPIRED

  submittedBy   String?
  submittedAt   DateTime @default(now())

  reviewedBy    String?
  reviewedAt    DateTime?

  reviewNotes   String?
  convertedSubscriptionId String?

  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([licenseId])
  @@index([status])
  @@index([status, createdAt])
}

model Activation {
  id         String   @id @default(cuid())

  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  deviceId   String
  deviceName String?

  ipAddress  String?
  os         String?
  osVersion  String?
  browser    String?
  browserVersion String?
  deviceType String?     // DESKTOP, MOBILE, TABLET, SERVER, OTHER
  userAgent  String?
  latitude   Float?
  longitude  Float?

  country    String?
  city       String?
  isp        String?

  trustScore Int      @default(50)
  isBlacklisted Boolean @default(false)
  lastSeenAt DateTime?
  status     String @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED, BLACKLISTED
  notes      String?

  createdAt  DateTime @default(now())

  deviceFingerprintId String?
  deviceFingerprint   DeviceFingerprint? @relation(fields: [deviceFingerprintId], references: [id])

  @@index([licenseId])
  @@index([deviceId])
  @@index([status])
  @@index([trustScore])
  @@index([deviceFingerprintId])
  @@index([licenseId, status])
  @@index([deviceId, status])
}

model DeviceFingerprint {
  id              String   @id @default(cuid())
  fingerprint     String   @unique
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  activationCount Int      @default(0)
  licenseIds      String?  // JSON
  activations     Activation[]
}

model AuditLog {
  id            String   @id @default(cuid())

  action        String

  severity      String   @default("Medium")

  entityType    String?

  entityId      String?

  metadata      String?

  licenseId     String?

  organization  String?

  actorRole     String?

  actorName     String?

  actorEmail    String?

  description   String?

  createdAt     DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorEmail])
  @@index([createdAt])
  @@index([licenseId])
  @@index([action, createdAt])
  @@index([actorEmail, createdAt])
  @@index([licenseId, createdAt])
  @@index([severity, createdAt])
}

model TeamMember {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique
  password  String

  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])

  status    String   @default("ACTIVE")

  licenseId String?     @unique
  license   License?    @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  lastLogin            DateTime?
  lastLoginIp          String?
  lastUserAgent        String?
  failedLoginAttempts  Int      @default(0)
  lockedUntil          DateTime?

  mfaSecret   String?
  mfaEnabled  Boolean  @default(false)

  passwordChangedAt DateTime?

  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?
  passwordSetupAt      DateTime?
  isFirstLogin         Boolean   @default(true)

  ssoProvider  String?
  ssoId        String?

  department String?
  phone      String?
  avatarUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  loginHistory  LoginHistory[]
  mfaBackupCodes MfaBackupCode[]
  notifications Notification[]
  temporaryPermissions TemporaryPermission[]

  @@index([roleId])
  @@index([status])
  @@index([email])
  @@index([status, roleId])
  @@index([licenseId])
}

model Session {
  id            String   @id @default(cuid())
  teamMemberId  String
  teamMember    TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  token         String    @unique
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  overrideDurationMinutes  Int?   // custom duration in minutes when policy is overridden
  overrideCooldownMinutes  Int?   // cooldown in minutes before next override is allowed
  lastOverrideAt           DateTime? // when the last override was applied

  // Session Fingerprinting
  fingerprint   SessionFingerprint?

  @@index([teamMemberId])
  @@index([expiresAt])
  @@index([teamMemberId, expiresAt])
  @@index([token, expiresAt])
}

model SessionFingerprint {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  ipAddress       String?
  country         String?
  countryName     String?
  region          String?
  city            String?
  isp             String?
  latitude        Float?
  longitude       Float?

  browser         String?
  browserVersion  String?
  os              String?
  osVersion       String?
  deviceType      String?   // DESKTOP, MOBILE, TABLET, SERVER, OTHER
  deviceId        String?   // fingerprint hash
  userAgent       String?

  firstSeen       DateTime  @default(now())
  lastSeen        DateTime  @default(now())

  riskScore       String    @default("LOW")   // LOW, MEDIUM, HIGH, CRITICAL
  riskFactors     String?   // JSON array of risk factor strings

  isNewDevice     Boolean   @default(false)
  isNewBrowser    Boolean   @default(false)
  isNewCountry    Boolean   @default(false)
  isNewRegion     Boolean   @default(false)
  ipChanged       Boolean   @default(false)
  deviceChanged   Boolean   @default(false)
  suspicious      Boolean   @default(false)

  metadata        String?   // JSON

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sessionId])
  @@index([deviceId])
  @@index([riskScore])
  @@index([suspicious])
  @@index([country])
  @@index([createdAt])
}

model SecurityAlert {
  id            String   @id @default(cuid())
  type          String   // LOGIN, LOGOUT, NEW_DEVICE, FAILED_LOGIN, LOCKED_ACCOUNT,
                         // PERMISSION_CHANGE, ROLE_CHANGE, TEMP_PERMISSION_GRANT, TEMP_PERMISSION_REVOKE,
                         // PREMIUM_GRANT, PREMIUM_REVOKE, LIFETIME_CONVERT,
                         // COINS_GRANTED, COINS_REMOVED, GEMS_GRANTED, GEMS_REMOVED,
                         // LICENSE_CREATE, LICENSE_TRANSFER, LICENSE_DELETE,
                         // ORG_CREATE, ORG_DELETE,
                         // TEAM_CREATE, TEAM_EDIT, TEAM_DELETE, OWNERSHIP_TRANSFER,
                         // HIGH_RISK_SESSION, SESSION_HIJACK, SUSPICIOUS_ACTIVITY
  severity      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title         String
  description   String?
  metadata      String?  // JSON

  entityType    String?  // session, team_member, license, organization, etc.
  entityId      String?

  actorId       String?
  actorName     String?
  actorEmail    String?

  resolved      Boolean  @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?

  createdAt     DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([severity, createdAt])
  @@index([type, createdAt])
}

model ApprovalRequest {
  id              String   @id @default(cuid())
  workflowType    String   // PREMIUM_GRANT, PREMIUM_EXTEND, PREMIUM_REVOKE, PREMIUM_PLAN_CHANGE,
                           // PREMIUM_LIFETIME_CONVERT, PREMIUM_CUSTOM_CONVERT,
                           // COINS_GRANT, COINS_REMOVE, COINS_SET,
                           // GEMS_GRANT, GEMS_REMOVE, GEMS_SET,
                           // LICENSE_CREATE, LICENSE_DELETE, LICENSE_TRANSFER, LICENSE_BULK,
                           // USER_BAN, USER_SUSPEND, USER_DELETE, USER_VERIFICATION,
                           // ROLE_CREATE, ROLE_DELETE, ROLE_PERMISSION_CHANGE,
                           // TEAM_CREATE, TEAM_EDIT, TEAM_DELETE, TEAM_ROLE_CHANGE, OWNERSHIP_TRANSFER,
                           // ORG_CREATE, ORG_EDIT, ORG_DELETE
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED, EXPIRED
  priority        String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL

  title           String
  description     String?
  reason          String?
  metadata        String?  // JSON payload with request details

  requesterId     String
  requesterName   String?
  requesterEmail  String?

  approverId      String?
  approverName    String?
  approverEmail   String?

  approvalNote    String?

  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  executedAt      DateTime?

  expiresAt       DateTime? // auto-expiry for time-sensitive approvals

  auditId         String?   // link to audit log entry

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workflowType])
  @@index([status])
  @@index([requesterId])
  @@index([approverId])
  @@index([status, workflowType])
  @@index([status, createdAt])
  @@index([requesterId, status])
  @@index([createdAt])
}

model TemporaryPermission {
  id              String    @id @default(cuid())
  permission      String    // the permission key being granted temporarily
  roleId          String?
  role            Role?     @relation(fields: [roleId], references: [id])
  teamMemberId    String?
  teamMember      TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  grantedById     String?
  grantedByName   String?
  grantedByEmail  String?

  duration        Int       // duration in minutes
  expiresAt       DateTime
  reason          String?

  active          Boolean   @default(true)
  revokedAt       DateTime?
  revokedById     String?

  auditLogId      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teamMemberId, active])
  @@index([roleId, active])
  @@index([expiresAt])
  @@index([permission])
  @@index([active, expiresAt])
}

model AuditChainLink {
  id              String    @id @default(cuid())
  auditLogId      String    @unique
  auditHash       String    @unique
  previousHash    String?   // null for genesis link
  chainIndex      Int       // sequential index in the chain

  action          String
  entityType      String?
  entityId        String?
  timestamp       DateTime

  integrityStatus String    @default("VERIFIED") // VERIFIED, TAMPERED, MISSING, UNVERIFIED

  createdAt       DateTime  @default(now())

  @@index([auditLogId])
  @@index([auditHash])
  @@index([previousHash])
  @@index([chainIndex])
  @@index([integrityStatus])
  @@index([chainIndex, integrityStatus])
}

model WaitlistEntry {
  id              String    @id @default(cuid())
  fullName        String
  email           String    @unique
  country         String?
  referralCode    String?   // the referrer's code
  interestCategory String?  // what they're interested in

  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, CONVERTED, INVITED
  position        Int       @unique             // position in the waitlist queue

  inviteSentAt    DateTime?
  invitedBy       String?
  approvedAt      DateTime?
  approvedBy      String?
  convertedAt     DateTime?
  convertedUserId String?   // if converted to actual user

  // Referral tracking
  ownReferralCode String    @unique             // this user's referral code
  referralCount   Int       @default(0)
  referralRank    Int       @default(0)
  referralConversionRate Float  @default(0)

  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([position])
  @@index([referralCode])
  @@index([ownReferralCode])
  @@index([status, position])
  @@index([referralCount, referralRank])
  @@index([createdAt])
}

model WaitlistInviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  maxUses         Int       @default(1)
  usedCount       Int       @default(0)
  createdBy       String?
  expiresAt       DateTime?
  active          Boolean   @default(true)

  createdAt       DateTime  @default(now())

  @@index([code])
  @@index([active, expiresAt])
}

model LoginHistory {
  id            String    @id @default(cuid())
  teamMemberId  String?
  teamMember    TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  email         String?
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([teamMemberId])
  @@index([createdAt])
}

model MfaBackupCode {
  id            String   @id @default(cuid())
  teamMemberId  String
  teamMember    TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  code          String
  used          Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Role {
  id          String   @id @default(cuid())

  name        String   @unique
  description String?

  riskLevel   String   @default("Medium")

  protected   Boolean  @default(false)

  permissionsVersion Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     TeamMember[]
  permissions Permission[]
  temporaryPermissions TemporaryPermission[]
}

model Permission {
  id          String   @id @default(cuid())

  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])

  permission  String

  createdAt   DateTime @default(now())

  @@index([roleId])
  @@index([permission])
  @@index([roleId, permission])
}

model SupportTicket {
  id         String   @id @default(cuid())
  subject    String
  message    String
  status     String   @default("OPEN")       // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority   String   @default("MEDIUM")     // LOW, MEDIUM, HIGH, CRITICAL
  category   String   @default("GENERAL")    // GENERAL, BILLING, TECHNICAL, ACCOUNT, OTHER

  licenseId  String?
  license    License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  assignedTo String?                          // TeamMember ID
  createdBy  String?
  resolvedBy String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes SupportNote[]

  @@index([status])
  @@index([assignedTo])
  @@index([licenseId])
  @@index([status, priority])
  @@index([createdAt])
}

model SupportNote {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  note       String
  isInternal Boolean  @default(true)
  createdBy  String?
  createdAt     DateTime @default(now())
}

model ModerationReport {
  id          String   @id @default(cuid())
  targetType  String                        // LICENSE, USER, CONTENT
  targetId    String
  reason      String
  description String?
  reporterId  String?
  status      String   @default("PENDING")  // PENDING, INVESTIGATING, RESOLVED, DISMISSED
  resolvedBy  String?
  resolvedAt  DateTime?
  actionTaken String?                        // WARNING, SUSPENSION, BAN, NONE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModerationAction {
  id            String   @id @default(cuid())
  targetType    String                        // LICENSE, USER, TEAM_MEMBER
  targetId      String
  actionType    String                        // WARNING, SUSPENSION, REINSTATEMENT, BAN
  reason        String
  durationDays  Int?
  expiresAt     DateTime?
  performedBy   String?
  reportId      String?
  createdAt     DateTime @default(now())
}

model Broadcast {
  id           String   @id @default(cuid())
  subject      String
  message      String
  type         String   @default("INFO")     // INFO, WARNING, CRITICAL
  audience     String   @default("ALL")       // ALL, PREMIUM, FREE, SPECIFIC
  status       String   @default("DRAFT")     // DRAFT, SCHEDULED, SENT, CANCELLED
  scheduledAt  DateTime?
  sentAt       DateTime?
  sentCount    Int      @default(0)
  targetCount  Int      @default(0)
  failedCount  Int      @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id            String   @id @default(cuid())
  teamMemberId  String
  teamMember    TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  title         String
  message       String
  type          String   @default("INFO")
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([teamMemberId, read])
  @@index([teamMemberId, createdAt])
}

model SecurityPolicy {
  id            String   @id @default(cuid())

  name          String   @unique

  enabled       Boolean  @default(true)

  description   String?

  category      String   @default("General")

  severity      String   @default("Medium")

  systemManaged Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Promotion {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  productType     String    // PROMO_CODE, DISCOUNT_COUPON, CAMPAIGN, LIMITED_TIME_OFFER, FREE_TRIAL, UPGRADE_PROMOTION
  appliesTo       String?   // PREMIUM, COIN, GEM, LICENSE
  targetPlan      String?   // plan/package label or plan ID when applicable
  discountType    String    // PERCENTAGE, FIXED
  discountValue   Float
  maxUses         Int?
  usedCount       Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  active          Boolean   @default(true)
  createdBy       String?
  metadata        String?   // JSON string for subtype-specific fields (perUserLimit, trialLength, fromPlan, campaignPromotions, etc.)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productType])
  @@index([active])
  @@index([active, endDate])
  @@index([appliesTo])
}

model Invoice {
  id                String    @id @default(cuid())
  invoiceNumber     String    @unique
  licenseId         String?
  license           License?  @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  organization      String?
  customerName      String?
  customerEmail     String?

  status            String    @default("PENDING") // DRAFT, PENDING, PAID, OVERDUE, CANCELLED, REFUNDED
  type              String    @default("SALE")     // SALE, REFUND, CREDIT
  category          String    @default("OTHER")   // PREMIUM, LICENSE, COIN, GEM, PROMOTION, ORGANIZATION, SESSION, OTHER
  action            String?                        // e.g. GRANT, EXTEND, CHANGE_PLAN, CREATE, REFUND

  subtotal          Int       @default(0)          // amount in cents
  discount          Int       @default(0)
  tax               Int       @default(0)
  total             Int       @default(0)
  currency          String    @default("USD")

  lineItems         String?   // JSON string [{ description, quantity, unitPrice, total }]

  issuedAt          DateTime  @default(now())
  dueAt             DateTime?
  paidAt            DateTime?

  notes             String?

  actorName         String?
  actorEmail        String?
  targetName        String?
  targetId          String?

  relatedEntityType String?   // e.g. PREMIUM_GRANT, LICENSE_CREATE, COIN_PURCHASE, GEM_PURCHASE, SESSION_EXTEND, PROMOTION
  relatedEntityId   String?

  shareToken        String?   @unique
  shareTokenExpiresAt DateTime?
  isArchived        Boolean   @default(false)
  archivedAt        DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([licenseId])
  @@index([status])
  @@index([category])
  @@index([action])
  @@index([issuedAt])
  @@index([status, issuedAt])
  @@index([organization, status])
  @@index([category, status])
}
