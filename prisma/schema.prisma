generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String

  createdAt DateTime @default(now())
}

model License {
  id           String   @id @default(cuid())
  key          String   @unique

  organization String
  plan         String
  status       String

  maxDevices   Int

  expiresAt    DateTime

  notes        String?

  createdAt    DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  activations  Activation[]
}

model Activation {
  id         String   @id @default(cuid())

  licenseId  String
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  deviceId   String
  deviceName String?

  ipAddress  String?

  createdAt  DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(cuid())

  action        String

  licenseId     String?

  organization  String?

  actorRole     String?

  actorName     String?

  description   String?

  createdAt     DateTime @default(now())
}
